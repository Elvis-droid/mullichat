{
  "expo": {
    "name": "MulliChat",
    "slug": "mullichat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fusesteam.mullichat"
    },
    "android": {
      "package": "com.fusesteam.mullichat",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "sdkVersion": "54.0.0",
    "platforms": ["ios", "android"],
    "extra": {
      "eas": {
        "projectId": "c8cc334c-420e-4e0e-b412-0f1d56efa5cd"
      }
    },
    "owner": "fuses-team"
  }
}
